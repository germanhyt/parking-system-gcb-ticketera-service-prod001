# ============================================
# CONFIGURACIÓN DEL AGENTE DE IMPRESIÓN
# ============================================

# WebSocket - Servidor de Producción
WEBSOCKET_SERVER_URL=wss://tu-dominio.com:8004
WEBSOCKET_APP_KEY=tu-reverb-app-key

# ============================================
# MODO DE OPERACIÓN
# ============================================
# Valores: "caja" o "puerta"
# - "caja": Para impresoras en cajas de cobro (comprobantes)
# - "puerta": Para impresoras en puertas de entrada/salida (tickets)
MODO=caja

# ============================================
# CONFIGURACIÓN DE CAJA (si MODO=caja)
# ============================================
# ⚠️ IMPORTANTE: Cambiar estos valores según la caja
CAJA_ID=1
CAJA_CODIGO=001
SEDE_NOMBRE=PÉRGOLA

# ============================================
# CONFIGURACIÓN DE PUERTA (si MODO=puerta)
# ============================================
# ⚠️ IMPORTANTE: Cambiar estos valores según la puerta
PUERTA_ID=1
PUERTA_NUMERO=Puerta 1
SEDE_ID=1

# ============================================
# IMPRESORA LOCAL
# ============================================
NOMBRE_IMPRESORA=POS-80

# ============================================
# SERVIDOR LOCAL (monitoreo)
# ============================================
PUERTO_LOCAL=4000

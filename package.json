{
  "name": "web-ticketera-service",
  "version": "1.0.0",
  "description": "Servicio local de impresión térmica para tickets",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npx ts-node src/index.ts",
    "reinstalar": "powershell -ExecutionPolicy Bypass -File ./scripts/reinstalar-caja.ps1",
    "install:caja": "npm install",
    "pruebas": "powershell -ExecutionPolicy Bypass -File ./scripts/ejecutar-pruebas.ps1",
    "test": "npm run pruebas",
    "typecheck": "tsc --noEmit",
    "watch": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18 <=20"
  },
  "keywords": [
    "printer",
    "thermal",
    "escpos",
    "ticket"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "pusher-js": "^8.4.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
